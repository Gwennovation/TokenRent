# =====================================================================
# T0kenRent — Environment Variables (TEMPLATE)
#
# 1) Copy this file:  cp .env.example .env
# 2) Fill in your real values in .env
# 3) NEVER commit .env — it's listed in .gitignore for a reason.
# =====================================================================

# --- Server ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- MongoDB Atlas ---
# Get this from your Atlas cluster: Connect → Drivers → copy URI
# Replace <username>, <password>, and the database name (e.g. /tokenrent)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/tokenrent?retryWrites=true&w=majority

# --- JWT (for signed auth cookies) ---
# Generate a long random string: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-48-chars
JWT_EXPIRES_IN=7d

# --- HandCash Connect ---
# Register at https://dashboard.handcash.io
# Add http://localhost:3000/auth/handcash/callback to your app's
# "Authorized Redirect URLs" before testing.
HANDCASH_APP_ID=your-handcash-app-id
HANDCASH_APP_SECRET=your-handcash-app-secret-NEVER-COMMIT

# --- Cloudinary (for item photo uploads) ---
# Sign up at https://cloudinary.com → Dashboard → copy these values
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Admin bootstrap ---
# The email below will be promoted to role=admin on first login.
# Set this to the email you'll register with as the admin user.
ADMIN_EMAIL=admin@example.com
